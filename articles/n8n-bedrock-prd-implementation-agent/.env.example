# Article 3: PRD/DesignDoc → Implementation Agent (n8n + Bedrock + GitHub + Google Drive)
# Copy this file to `.env`, fill in the values, then `set -a; source .env; set +a` before
# running scripts. Never commit `.env`.

# --- AWS context ---
AWS_PROFILE=n8n-admin
AWS_DEFAULT_REGION=ap-northeast-1
AWS_ACCOUNT_ID=

# --- GitHub Personal Access Token ---
# Required scopes: repo, pull-requests
# Generate at https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=

# --- Bedrock model id (default: JP profile of Claude Sonnet 4.6) ---
BEDROCK_SONNET_MODEL_ID=jp.anthropic.claude-sonnet-4-6

# --- n8n EC2 SSH (used by step 04 manual instructions) ---
N8N_SSH_TARGET=                  # ubuntu@<your-ec2-ip>
N8N_SSH_KEY=~/.ssh/n8n-key.pem

# --- Form Trigger shared secret ---
# Generate with: openssl rand -base64 32
# Distribute out-of-band to authorized users; paste into the form's "Shared Secret" field.
PRD_AGENT_FORM_SECRET=

# --- Google Drive folder id where PRD/DesignDoc Google Docs will be created ---
# Read from Drive URL: https://drive.google.com/drive/folders/<this part>
GOOGLE_DRIVE_FOLDER_ID=
