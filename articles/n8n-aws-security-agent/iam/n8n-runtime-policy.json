{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InvokeAgentLambdas",
      "Effect": "Allow",
      "Action": ["lambda:InvokeFunction"],
      "Resource": [
        "arn:aws:lambda:${AWS_DEFAULT_REGION}:${AWS_ACCOUNT_ID}:function:aws-security-investigator-readonly",
        "arn:aws:lambda:${AWS_DEFAULT_REGION}:${AWS_ACCOUNT_ID}:function:aws-security-investigator-readonly:*",
        "arn:aws:lambda:${AWS_DEFAULT_REGION}:${AWS_ACCOUNT_ID}:function:aws-security-bedrock-summarize",
        "arn:aws:lambda:${AWS_DEFAULT_REGION}:${AWS_ACCOUNT_ID}:function:aws-security-bedrock-summarize:*"
      ]
    }
  ]
}
