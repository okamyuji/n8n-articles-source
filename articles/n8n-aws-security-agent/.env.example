# Article 2: AWS Security Agent (GuardDuty -> EventBridge -> Lambda -> n8n -> Bedrock -> Slack)
# Copy this file to `.env`, fill in the values, then `set -a; source .env; set +a` before
# running scripts. Never commit `.env`.

# --- AWS context ---
AWS_PROFILE=n8n-admin
AWS_DEFAULT_REGION=ap-northeast-1
AWS_ACCOUNT_ID=
KMS_KEY_ID=                      # uuid of the customer-managed KMS key created in article 1
KMS_ALIAS=alias/n8n-secrets

# --- n8n endpoint exposed by article 1 ---
N8N_WEBHOOK_URL=                 # https://<your-n8n-domain>/webhook/aws-security-finding

# --- Bearer token used by relay Lambda <-> n8n Header Auth credential ---
# Generate with: openssl rand -hex 32   (do NOT echo into a file you commit)
N8N_WEBHOOK_BEARER=

# --- Slack Incoming Webhook ---
SLACK_WEBHOOK_URL=               # https://hooks.slack.com/services/.../.../...

# --- Bedrock model id (default: JP profile of Claude Haiku 4.5) ---
BEDROCK_HAIKU_MODEL_ID=jp.anthropic.claude-haiku-4-5-20251001-v1:0
