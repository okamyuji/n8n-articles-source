# Article 1: n8n self-host on AWS (EC2 + KMS + SSM + Cloudflare DNS)
# Copy this file to `.env`, fill in the values, then `set -a; source .env; set +a` before
# running scripts. Never commit `.env`.

# --- AWS context ---
AWS_PROFILE=n8n-admin
AWS_DEFAULT_REGION=ap-northeast-1
AWS_ACCOUNT_ID=

# --- n8n hostname (your Cloudflare-managed FQDN) ---
N8N_DOMAIN=

# --- Operator IP for the SSH security group rule ---
# Auto-detected via https://checkip.amazonaws.com if left empty.
MY_IP=

# --- Generated by step 01 (export to your shell after running step 01 if you reuse it) ---
KMS_KEY_ID=

# --- Filled in by step 03 / 04 / 05 outputs (export them so subsequent steps see them) ---
SG_ID=
INSTANCE_ID=
EIP_ALLOC_ID=
EC2_PUBLIC_IP=

# --- Optional overrides for /n8n/prod SSM params (otherwise generated/defaulted) ---
USER_MANAGEMENT_DISABLED=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# --- Used only by ec2/cron/backup.sh on the EC2 host ---
BACKUP_BUCKET_NAME=
