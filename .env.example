# Common environment variables shared across all 3 article subprojects.
# Copy this file to `.env`, fill in the values, then `set -a; source .env; set +a`.
# Never commit the real `.env` file (it is in .gitignore).

# --- AWS context ---
AWS_PROFILE=
AWS_DEFAULT_REGION=ap-northeast-1
AWS_ACCOUNT_ID=

# --- Operator IP for SSH security group rule ---
MY_IP=

# --- n8n self-host (article 1) ---
N8N_DOMAIN=
EC2_PUBLIC_IP=
EIP_ALLOC_ID=

# --- AWS Security Agent (article 2) ---
SLACK_WEBHOOK_URL=
GUARDDUTY_DETECTOR_ID=
N8N_WEBHOOK_URL=
N8N_WEBHOOK_BEARER=
BEDROCK_HAIKU_MODEL_ID=jp.anthropic.claude-haiku-4-5-20251001-v1:0

# --- PRD Implementation Agent (article 3) ---
GITHUB_OWNER=
GITHUB_REPO=
GEMINI_API_KEY=
GOOGLE_DRIVE_FOLDER_ID=
PRD_AGENT_FORM_SECRET=
BEDROCK_SONNET_MODEL_ID=jp.anthropic.claude-sonnet-4-6-20251022-v1:0
GITHUB_TOKEN=
